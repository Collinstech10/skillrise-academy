# Server
PORT=5000
NODE_ENV=development

# Supabase — get from supabase.com > Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# JWT — use a strong random string
JWT_SECRET=your_strong_jwt_secret_here
JWT_EXPIRES_IN=7d

# Paystack — get from dashboard.paystack.com
PAYSTACK_SECRET_KEY=sk_live_or_test_your_key_here
PAYSTACK_PUBLIC_KEY=pk_live_or_test_your_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Admin seed account
ADMIN_EMAIL=admin@skillrise.com
ADMIN_PASSWORD=Admin@123
